NODE_ENV=production
PORT=4000
REDIS_URL=redis://redis:6379
CORS_ORIGIN=https://makemoneyordie.com
SITE_URL=https://makemoneyordie.com
JWT_SECRET=replace-with-generated-stable-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-generated-stable-secret
OPENROUTER_API_KEY=sk-or-v1-replace-with-new-key
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_SITE_URL=https://makemoneyordie.com
OPENROUTER_TIMEOUT_MS=90000
OPENROUTER_MAX_INPUT_CHARS=16000
OPENROUTER_MAX_OUTPUT_TOKENS=9000
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_RETRY_ATTEMPTS=3
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MakeMoneyOrDie <newsletter@example.com>"
